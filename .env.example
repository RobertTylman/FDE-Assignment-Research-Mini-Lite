# Required for the default OpenAI chat model.
OPENAI_API_KEY=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

# Required for the Tavily web_search tool.
TAVILY_API_KEY=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

# OpenAI model name used by ChatOpenAI.
OPENAI_MODEL=gpt-4.1-mini

# OpenAI sampling temperature. Lower values make answers more deterministic.
OPENAI_TEMPERATURE=0.1

# Optional OpenAI request timeout in seconds. Leave unset to use the SDK default.
# OPENAI_TIMEOUT_SECONDS=30

# Optional OpenAI retry count. Leave unset to use the SDK default.
# OPENAI_MAX_RETRIES=2

# Optional maximum output tokens for each OpenAI response. Leave unset for no local cap.
# OPENAI_MAX_TOKENS=700

# Maximum number of tool calls the agent may make before forced final synthesis.
MAX_TOOL_ITERATIONS=5

# Tavily request timeout in seconds.
TAVILY_TIMEOUT_SECONDS=30

# Maximum number of Tavily search results returned per web_search call.
TAVILY_MAX_RESULTS=5

# Tavily search depth. Use "basic" for speed or "advanced" for deeper search.
TAVILY_SEARCH_DEPTH=basic

# Whether Tavily should include its generated answer field in the response.
TAVILY_INCLUDE_ANSWER=false

# Whether Tavily should include raw page content. This can substantially increase payload size.
TAVILY_INCLUDE_RAW_CONTENT=false

# Optional maximum characters per returned snippet. Leave unset to keep Tavily snippets unchanged.
# TAVILY_SNIPPET_CHARS=700
